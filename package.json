{
  "name": "hoist",
  "version": "0.0.0",
  "description": "Install agent harnesses. Manage your keys. Wire up your gateway.",
  "author": "echoHello",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.node.json && electron dist/main/index.js",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "start": "electron dist/main/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
